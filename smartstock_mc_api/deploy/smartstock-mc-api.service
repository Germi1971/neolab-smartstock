[Unit]
Description=SmartStock Monte Carlo API - Sugerencias de reposición
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=__WORK_DIR__
Environment="PATH=__WORK_DIR__/venv/bin"
EnvironmentFile=__WORK_DIR__/.env
ExecStart=__WORK_DIR__/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
