# Copiar a .env en el servidor Lightsail
# cp deploy/env.lightsail.example .env && nano .env

# MySQL - En AWS usar ss2_staging (clon de neolab con mismas tablas)
# Endpoint: IP Lightsail, RDS, o 127.0.0.1 si MySQL está en la misma instancia
MYSQL_HOST=TU_MYSQL_HOST
MYSQL_PORT=3306
MYSQL_USER=ss2
MYSQL_PASSWORD=TU_PASSWORD_MYSQL
MYSQL_DB=ss2_staging

# Opcional: Lead time operativo (días)
LT_OPERATIVO_DEFAULT=60

# Opcional: Niveles de servicio por criticidad
# SERVICE_CRITICO=0.95
# SERVICE_IMPORTANTE=0.90
# SERVICE_NO_CRITICO=0.50
